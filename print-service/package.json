{
  "name": "corcega-print-service",
  "version": "2.0.0",
  "description": "Servicio de impresión automática para Córcega Café",
  "main": "index.js",
  "scripts": {
    "start":     "node index.js",
    "start-pdf": "node index-pdf.js",
    "start-ui":  "node index-ui.js",
    "preview":   "node preview.js",
    "build":     "pkg index.js     --targets node18-win-x64 --output corcega-print.exe     --compress GZip",
    "build-pdf": "pkg index-pdf.js --targets node18-win-x64 --output corcega-print-pdf.exe --compress GZip",
    "build-ui":  "pkg index-ui.js  --targets node18-win-x64 --output corcega-print-ui.exe  --compress GZip"
  },
  "pkg": {
    "assets": [
      "config.json",
      "ticket.js",
      "ticket-pdf.js",
      "escpos.js",
      "index-ui.js",
      "node_modules/pdfkit/js/data/**",
      "node_modules/pdfkit/js/data/*.afm",
      "node_modules/pdfkit/js/data/*.icc"
    ]
  },
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "pdfkit": "^0.18.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
